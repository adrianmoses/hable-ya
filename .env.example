# LLM (served by llama.cpp, OpenAI-compatible endpoint)
HABLE_YA_LLAMA_CPP_URL=http://localhost:8080
HABLE_YA_LLM_MODEL_NAME=gemma-4-e4b-finetuned
HABLE_YA_LLM_MAX_TOKENS=150

# App
HABLE_YA_DB_PATH=./hable_ya.db
HABLE_YA_HOST=0.0.0.0
HABLE_YA_PORT=8000
HABLE_YA_LOG_LEVEL=info

# Whisper STT (small + cuda/float16 by default — CPU falls back to compute_type=int8)
HABLE_YA_WHISPER_MODEL=small
HABLE_YA_WHISPER_DEVICE=cuda
HABLE_YA_WHISPER_COMPUTE_TYPE=float16

# Piper TTS (castellano, x_low = fastest; _low/_medium available for quality)
HABLE_YA_PIPER_VOICE=es_ES-carlfm-x_low
HABLE_YA_PIPER_MODEL_DIR=~/piper_models

# Turn-taking
HABLE_YA_SMART_TURN_STOP_SECS=4.0
HABLE_YA_VAD_STOP_SECS=0.5
HABLE_YA_AUDIO_SAMPLE_RATE=16000

# Anthropic (only needed for fixture generation, recast judging, agent eval)
# ANTHROPIC_API_KEY=

# HuggingFace (Gemma is gated — needed by scripts/download_model.py)
# HF_TOKEN=
